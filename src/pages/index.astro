---
import { getCollection } from "astro:content";
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import Socials from "@/components/Socials.astro";
import LinkButton from "@/components/LinkButton.astro";
import Card from "@/components/Card.astro";
import Tag from "@/components/Tag.astro";
import TechStack from "@/components/TechStack.astro";
import CTA from "@/components/CTA.astro";
import getSortedPosts from "@/utils/getSortedPosts";
import getUniqueTags from "@/utils/getUniqueTags";
import IconArrowRight from "@/assets/icons/IconArrowRight.svg";
import { SOCIALS } from "@/constants";

const posts = await getCollection("blog");

const sortedPosts = getSortedPosts(posts);
const featuredPosts = sortedPosts.filter(({ data }) => data.featured);
const tags = getUniqueTags(posts);
---

<Layout>
  <Header />
  <main id="main-content" data-layout="index" class="app-layout">
    <section id="hero" class:list={["pt-8 pb-6", "border-b border-border"]}>
      <div class="flex flex-col-reverse sm:flex-row items-center gap-4">
        <div class="flex-[2]">
          <h1 class="my-4 inline-block text-3xl font-bold sm:my-8 sm:text-4xl text-accent">
            Cloud & K8s Architect
          </h1>

          <p class="text-lg font-semibold">
            Empowering Business with Modern Cloud Solutions
          </p>

          <p class="mt-4 text-lg leading-relaxed">
            I have <span class="text-accent font-semibold">10+ years of experience</span>
            in building and scaling cloud-native ecosystems focusing on infrastructure automation and platform engineering.
            <br class="mb-2" />
            Expert in <span class="text-accent font-semibold">Kubernetes & GitOps-driven</span>
            architectures with a strong track record of building robust CI/CD pipelines.
          </p>

          {
            // only display if at least one social link is enabled
            SOCIALS.length > 0 && (
              <div class="mt-4 flex max-sm:flex-col sm:items-center">
                <div class="me-2 mb-1 whitespace-nowrap sm:mb-0">Social Links:</div>
                <Socials />
              </div>
            )
          }
        </div>
        <div class="flex-1 flex justify-center sm:justify-end">
          <a
            href="https://calendar.app.google/z24Xp6WWH1Rzwrk78"
            target="_blank"
            class="group block"
            aria-label="Access expert advice"
          >
            <img
              src="/cloud-k8s.png"
              alt="Alex Medvedev"
              class="rounded-full w-48 h-48 sm:w-64 sm:h-64 object-cover [-webkit-mask-image:radial-gradient(circle,black_30%,transparent_70%)] [mask-image:radial-gradient(circle,black_30%,transparent_70%)] animate-float group-hover:scale-105 transition-transform"
            />
          </a>
        </div>
      </div>
    </section>

    <TechStack />

    {
      featuredPosts.length > 0 && (
        <section
          id="featured"
          class:list={[
            "pt-12 pb-6",
            { "border-b border-border": tags.length > 0 },
          ]}
        >
          <h2 class="text-2xl font-semibold tracking-wide">Featured</h2>
          <ul>
            {featuredPosts.map(data => (
              <Card variant="h3" {...data} />
            ))}
          </ul>
        </section>
      )
    }

    {
      tags.length > 0 && (
        <section id="tags" class="pt-12 pb-6">
          <h2 class="text-2xl font-semibold tracking-wide mb-4">Tags</h2>
          <ul class="flex flex-wrap gap-4">
            {tags.map(tag => (
              <Tag {...tag} size="lg" />
            ))}
          </ul>
        </section>
      )
    }

    <CTA />

    <div class="my-8 text-center">
      <LinkButton href="/posts/">
        All Posts
        <IconArrowRight class="inline-block rtl:-rotate-180" />
      </LinkButton>
    </div>
  </main>
  <Footer />
</Layout>

<script>
  document.addEventListener("astro:page-load", () => {
    const indexLayout = (document.querySelector("#main-content") as HTMLElement)
      ?.dataset?.layout;
    if (indexLayout) {
      sessionStorage.setItem("backUrl", "/");
    }
  });
</script>
